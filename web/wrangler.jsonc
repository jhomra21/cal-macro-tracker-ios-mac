{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "MACROS-web",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
  "d1_databases": [
    {
      "binding": "SUPPORT_DB",
